# ============================================
# Environment Configuration
# ============================================
NODE_ENV=development

# ============================================
# Server Configuration
# ============================================
PORT=5000

# ============================================
# Database Configuration
# ============================================
MONGO_URI=mongodb://localhost:27017/kofilarteystudios

# ============================================
# Frontend URL (for CORS)
# ============================================
FRONTEND_URL=https://your-frontend-domain.com

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# ============================================
# Email/SMTP Configuration (REQUIRED!)
# ============================================
# For Gmail:
#   1. Enable 2-Factor Authentication
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-character password below
#   4. Keep port 587 for STARTTLS

EMAIL_FROM=noreply@kofilarteystudios.com
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Debug SMTP connections (set to 'true' only during troubleshooting)
DEBUG_MAILER=false

# Alternative SMTP Providers:
# Outlook:    SMTP_HOST=smtp-mail.outlook.com, SMTP_PORT=587
# SendGrid:   SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587
# AWS SES:    SMTP_HOST=email-smtp.{region}.amazonaws.com, SMTP_PORT=587

# ============================================
# Cloudinary Configuration (for image uploads)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
